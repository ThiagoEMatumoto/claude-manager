{
  "name": "claude-manager",
  "version": "0.5.2",
  "description": "Visual manager for multiple Claude Code sessions, projects, and configs",
  "main": "out/main/index.js",
  "type": "module",
  "author": "Thiago Matumoto",
  "license": "MIT",
  "homepage": "https://github.com/ThiagoEMatumoto/claude-manager",
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "node-gyp": "^11.5.0"
  },
  "scripts": {
    "dev": "electron-vite dev -- --no-sandbox",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3 -w node-pty",
    "dist": "npm run rebuild:native && electron-vite build && electron-builder",
    "dist:linux": "npm run rebuild:native && electron-vite build && electron-builder --linux AppImage deb",
    "dist:mac": "npm run rebuild:native && electron-vite build && electron-builder --mac dmg zip",
    "dist:win": "npm run rebuild:native && electron-vite build && electron-builder --win nsis",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "dependencies": {
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^11.10.0",
    "chokidar": "^5.0.0",
    "dockview": "^6.6.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.17.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-git": "^3.36.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-darwin-arm64": "^4.0.0",
    "@tailwindcss/oxide-darwin-x64": "^4.0.0",
    "@tailwindcss/oxide-linux-x64-gnu": "^4.0.0",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^32.3.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "node-gyp": "^11.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
