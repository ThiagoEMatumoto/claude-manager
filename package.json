{
  "name": "claude-manager",
  "version": "0.0.1",
  "description": "Visual manager for multiple Claude Code sessions, projects, and configs",
  "main": "out/main/index.js",
  "type": "module",
  "author": "Thiago Matumoto",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "node-gyp": "^11.5.0"
  },
  "scripts": {
    "postinstall": "node scripts/fix-pty-prebuilds.mjs",
    "dev": "electron-vite dev -- --no-sandbox",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.14.0",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^11.10.0",
    "chokidar": "^5.0.0",
    "emoji-mart": "^5.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-git": "^3.36.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-darwin-arm64": "^4.0.0",
    "@tailwindcss/oxide-darwin-x64": "^4.0.0",
    "@tailwindcss/oxide-linux-x64-gnu": "^4.0.0",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^32.3.3",
    "electron-vite": "^2.3.0",
    "node-gyp": "^11.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
