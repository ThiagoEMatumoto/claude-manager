{
  "name": "claude-manager",
  "version": "0.21.0",
  "description": "Visual manager for multiple Claude Code sessions, projects, and configs",
  "main": "out/main/index.js",
  "type": "module",
  "author": "Thiago Matumoto",
  "license": "MIT",
  "homepage": "https://github.com/ThiagoEMatumoto/claude-manager",
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "node-gyp": "^11.5.0"
  },
  "scripts": {
    "dev": "electron-vite dev -- --no-sandbox",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3 -w node-pty",
    "dist": "npm run rebuild:native && electron-vite build && electron-builder",
    "dist:linux": "npm run rebuild:native && electron-vite build && electron-builder --linux AppImage deb",
    "dist:mac": "npm run rebuild:native && electron-vite build && electron-builder --mac dmg zip",
    "dist:win": "npm run rebuild:native && electron-vite build && electron-builder --win nsis",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web && npm run typecheck:test",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "drive": "tsx e2e/scenarios/validate-projects.ts",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/node": "^2.0.0-alpha.2",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.11.0",
    "better-sqlite3": "^11.10.0",
    "chokidar": "^5.0.0",
    "dockview": "^6.6.1",
    "electron-updater": "^6.8.3",
    "fflate": "^0.8.3",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.17.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "simple-git": "^3.36.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-darwin-arm64": "^4.0.0",
    "@tailwindcss/oxide-darwin-x64": "^4.0.0",
    "@tailwindcss/oxide-linux-x64-gnu": "^4.0.0",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@modelcontextprotocol/client": "^2.0.0-alpha.2",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^32.3.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "jsdom": "^25.0.1",
    "node-gyp": "^11.5.0",
    "playwright": "^1.60.0",
    "sql.js": "^1.14.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  }
}
